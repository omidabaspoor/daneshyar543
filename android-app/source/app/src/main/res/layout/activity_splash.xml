<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f1115"
    android:gravity="center">

    <!-- مرکز: لوگو و عنوان -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- لوگو -->
        <ImageView
            android:id="@+id/splash_logo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/splash_icon"
            android:contentDescription="دانش‌یار" />

        <!-- عنوان -->
        <TextView
            android:id="@+id/splash_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="دانش‌یار"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif" />

        <!-- زیرعنوان -->
        <TextView
            android:id="@+id/splash_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="هم‌کلاسی هوشمند تو"
            android:textColor="#eb7c2a"
            android:textSize="16sp"
            android:fontFamily="sans-serif" />

    </LinearLayout>

    <!-- لودینگ در پایین -->
    <LinearLayout
        android:id="@+id/splash_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="60dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminateTint="#eb7c2a"
            android:indeterminateTintMode="src_in" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="در حال بارگذاری..."
            android:textColor="#888888"
            android:textSize="14sp" />

    </LinearLayout>

</RelativeLayout>
